Cell[CellGroupData[{

Cell["3+1 decomposition", "Subsection",
 CellChangeTimes->{{3.7110889754104548`*^9, 
  3.7110889827640953`*^9}},ExpressionUUID->"e16dd6b4-42ac-4dde-b8b5-\
1242440352f2"],

Cell["\<\
3 + 1 or 1+3 decomposition of spacetimes helps us to study the kinematical \
equations of motions, the properties of congruence of a vector field by \
associating certain kinematical quanties. It also tries to decouple the \
partial differential equations in spacetime to space and time. Hence to get a \
physical understanding of the equations.\
\>", "Text",
 CellChangeTimes->{{3.926563613063303*^9, 
  3.9265637451002407`*^9}},ExpressionUUID->"1dd41e35-9fd0-0840-a68f-\
e1eddb8dfdc1"],

