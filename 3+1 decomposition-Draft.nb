Cell[CellGroupData[{

Cell["Conditions and rules on Christoffel", "Subsubsection",
 CellChangeTimes->{{3.926488708553774*^9, 
  3.9264887215508766`*^9}},ExpressionUUID->"1bda747c-4f63-7b4b-829e-\
d816876f90f0"],

Cell["\<\
Conditions on the Christoffel Symbols, namely the Fermi condition where the \
Christoffel Symbol vanish on the worldline, and consequently the derivative \
of the metric vanishes (vice versa ,Actually we can show on the geodesics, we \
can adapt tetrads such that the Christoffels vanishes). The metric expands to \
first order to Minkowski metric. 
Certain comments on the following lines of code:
* We tried to achieve the vanishing Christoffel sumbols by the ruled, but it \
is very dangerous as it puts the head of the Christoffel Symbols to zero \
irrespective of how its appears, and hence we should use imploded tensor \
while using that rule. 
* Or we can apply the rule after changing the indices to all spacetime, \
instead of other vector bundles.   \
\>", "Text",
 CellChangeTimes->{{3.9265631697598057`*^9, 3.9265632806848183`*^9}, {
  3.926563770115881*^9, 3.926564041278269*^9}, {3.9265652412856865`*^9, 
  3.9265653092674065`*^9}},ExpressionUUID->"c77ae847-8d9a-144e-86f6-\
07aecb75f279"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"flatRule", "=", 
   RowBox[{"MakeRule", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"ChristoffelCD", "[", 
        RowBox[{"\[Alpha]", ",", 
         RowBox[{"-", "\[Beta]"}], ",", 
         RowBox[{"-", "\[Gamma]"}]}], "]"}], ",", "0"}], "}"}], ",", 
     RowBox[{"MetricOn", "->", "All"}]}], "]"}]}], 
  RowBox[{"(*", 
   RowBox[{"Prefer", " ", "ruled", " ", "after", " ", "Implode"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rule2", " ", "=", " ", 
   RowBox[{
    RowBox[{"ChristoffelCD", "[", 
     RowBox[{
      RowBox[{"_", "?", "TangentM`Q"}], ",", 
      RowBox[{"-", 
       RowBox[{"_", "?", "TangentM3`Q"}]}], ",", 
      RowBox[{"-", 
       RowBox[{"_", "?", "TangentM3`Q"}]}]}], "]"}], "->", "0"}]}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"No", " ", "need"}], ",", " ", 
    RowBox[{"plus", " ", "minus", " ", "documentation"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ruled", " ", "=", " ", 
   RowBox[{
    RowBox[{"ChristoffelCD", "[", "__", "]"}], "->", "0"}]}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Define", " ", "zeroth", " ", "order", " ", "to", " ", "zero"}], 
    ",", " ", 
    RowBox[{
    "but", " ", "this", " ", "puts", " ", "every", " ", "order", " ", "to", 
     " ", "zero"}], ",", " ", 
    RowBox[{"but", " ", "Implode"}]}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"fermicondi2", "=", 
  RowBox[{"MakeRule", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"PDChristoffelCD", "[", 
       RowBox[{"\[Alpha]", ",", 
        RowBox[{"-", "\[Beta]"}], ",", 
        RowBox[{"-", "\[Gamma]"}], ",", 
        RowBox[{"-", "t"}]}], "]"}], ",", "0"}], "}"}], ",", 
    RowBox[{"MetricOn", "->", "All"}], ",", 
    RowBox[{"ContractMetrics", "->", "True"}]}], 
   "]"}]}], "\[IndentingNewLine]"}], "Input",
