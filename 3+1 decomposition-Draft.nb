4630a4fd7fc8"],

Cell["\<\
Implode function in Mathematica defines abstractly a tensor by combining its \
derivative with the head. Hence the rules can be defined on it and its very \
convenient to handle.\
\>", "Text",
 CellChangeTimes->{{3.926561804333935*^9, 3.9265618215990086`*^9}, {
  3.926563088636404*^9, 
  3.926563142812844*^9}},ExpressionUUID->"db665cd8-e630-5f44-b5f3-\
fbe32b7aaa9f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"PD", "[", 
    RowBox[{"-", "\[Mu]"}], "]"}], "@", 
   RowBox[{
    RowBox[{"PD", "[", 
     RowBox[{"-", "\[Nu]"}], "]"}], "@", 
